{
  "name": "taiji-ai",
  "version": "0.7.3",
  "description": "太极Ai",
  "main": ".out/main/index.js",
  "author": "Ni But Crazy",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NiButCrazy/TaiJi-Ai-client.git"
  },
  "scripts": {
    "start": "chcp 65001 && electron-vite preview ",
    "dev": "chcp 65001 && electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:app",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "version": "nbc-auto-changelog -p && git add CHANGELOG.md"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^38.8.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.1",
    "less": "^4.6.4",
    "nbc-auto-changelog": "^1.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0",
    "typescript": "^5.9.3",
    "vite": "7.1.12",
    "zustand": "^5.0.12"
  }
}
